# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Required for JWT signing. Replace in production with a long random key.
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Optional AI descriptions/location estimation.
# Leave empty and the app still works without AI.
GEMINI_API_KEY=

# Optional real email delivery.
# Leave SMTP_USER and SMTP_PASS empty to use Ethereal test emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
